<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xmlns:android="http://schemas.android.com/apk/res/android" xsi:noNamespaceSchemaLocation="layout.xsd"
            android:layout_height="match_parent" android:layout_width="match_parent">
    <LinearLayout android:layout_height="match_parent" android:layout_width="match_parent"
                  android:orientation="vertical" android:padding="20dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:text="星穹铁道详细设置" android:textSize="18sp" android:textStyle="bold"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal" android:paddingTop="10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="启动方式"/>
            <Spinner android:layout_width="match_parent" android:layout_height="wrap_content"
                     android:tag="starrailLaunchMode" android:text="本地启动|星穹铁道云游戏|网易云游戏"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal" android:paddingTop="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="包名启动"/>
            <Spinner android:layout_width="match_parent" android:layout_height="wrap_content"
                     android:tag="starrailPackageName" android:text="" android:mode="dialog"/>
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:paddingTop="8dp" android:text="软件启动方式"/>
        <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content"
                     android:tag="starrailStartByPackage" android:text="包名启动"/>
        <RadioButton android:layout_width="match_parent" android:layout_height="wrap_content"
                     android:tag="starrailStartByNode" android:text="节点启动"/>
        <Switch android:tag="starrailEnable" android:text="启用星穹铁道任务"/>
        <Switch android:tag="starrailAutoBattle" android:text="自动战斗"/>
        <Switch android:tag="starrailUseSkill" android:text="优先施放秘技/战技"/>
        <Switch android:tag="starrailUseYolo" android:text="启用完善版 YOLO 识别"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal" android:paddingTop="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="YOLO 模型路径"/>
            <EditText android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:tag="starrailYoloOnnxPath" android:hint="/sdcard/MyFirstScript/models/SJZ.onnx"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal" android:paddingTop="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="YOLO 置信度"/>
            <EditText android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:tag="starrailYoloConfidence" android:hint="0.60" android:inputType="numberDecimal"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal" android:paddingTop="10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="清体力次数"/>
            <EditText android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:tag="starrailStaminaTimes" android:hint="4" android:inputType="number"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal" android:paddingTop="10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="找图相似度"/>
            <EditText android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:tag="starrailSimilarity" android:hint="0.82" android:inputType="numberDecimal"/>
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:paddingTop="12dp" android:text="账号设置"/>
        <Switch android:tag="starrailAccountSwitchEnable" android:text="星穹铁道启用自动换号"/>
        <EditText android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:tag="starrailAccountList" android:hint="账号1,账号2,账号3"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal" android:paddingTop="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="换号间隔(分钟)"/>
            <EditText android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:tag="starrailSwitchIntervalMin" android:hint="30" android:inputType="number"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
